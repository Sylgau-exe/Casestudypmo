{
  "redirects": [
    { "source": "/", "destination": "/pmo", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/pmo",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/plan", "destination": "/plan.html" },
    { "source": "/pmo", "destination": "/pmo.html" },
    { "source": "/negotiate", "destination": "/negotiate-login.html" },
    { "source": "/negotiate/dashboard", "destination": "/negotiate-dashboard.html" },
    { "source": "/negotiate/play", "destination": "/negotiate-play.html" },
    { "source": "/negotiate/results", "destination": "/negotiate-results.html" }
  ]
}
